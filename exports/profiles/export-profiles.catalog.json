{
  "version": "0.1.0",
  "profiles": [
    {
      "profile_id": "generic-json",
      "version": "0.1.0",
      "display_name": "Generic JSON Package",
      "target_tool": "Generic JSON",
      "target_category": "generic-json",
      "input_package_types": [
        "scene-package",
        "sequence-package",
        "trailer-package",
        "feature-package",
        "pitch-package",
        "audio-package"
      ],
      "required_fields": [
        {
          "source_path": "$.project.slug",
          "description": "Project slug"
        },
        {
          "source_path": "$.scenes[*].scene_id",
          "description": "Scene identifiers"
        },
        {
          "source_path": "$.scenes[*].shots[*].visual_prompt",
          "description": "Shot visual prompts"
        }
      ],
      "optional_fields": [
        {
          "source_path": "$.canon_refs",
          "description": "Canon references",
          "severity_if_missing": "warning"
        },
        {
          "source_path": "$.export_targets",
          "description": "Requested export targets",
          "severity_if_missing": "warning"
        }
      ],
      "limits": {
        "supports_reference_images": true,
        "supports_audio": true,
        "supports_dialogue": true
      },
      "rendering_rules": [
        "Preserve canonical structure with minimal transformation.",
        "Include source_refs, canon_refs, visual_refs, and generation_job_id when present."
      ],
      "output": {
        "format": "json",
        "file_extension": ".json",
        "naming_pattern": "{project_slug}-{package_id}-generic.json",
        "sections": [
          "metadata",
          "sources",
          "characters",
          "scenes",
          "shots",
          "exports"
        ]
      },
      "validation_rules": [
        "Package must contain at least one scene and one shot.",
        "Every shot should have a visual_prompt."
      ]
    },
    {
      "profile_id": "runway",
      "version": "0.1.0",
      "display_name": "Runway Scene Prompt Package",
      "target_tool": "Runway",
      "target_category": "ai-video",
      "input_package_types": [
        "scene-package",
        "sequence-package",
        "trailer-package"
      ],
      "required_fields": [
        {
          "source_path": "$.scenes[*].shots[*].visual_prompt",
          "description": "Shot-level video prompt"
        },
        {
          "source_path": "$.scenes[*].shots[*].camera",
          "description": "Camera direction"
        }
      ],
      "optional_fields": [
        {
          "source_path": "$.scenes[*].shots[*].reference_assets",
          "description": "Reference images/assets",
          "severity_if_missing": "warning"
        },
        {
          "source_path": "$.scenes[*].shots[*].negative_prompt",
          "description": "Negative prompt",
          "severity_if_missing": "warning"
        }
      ],
      "limits": {
        "recommended_aspect_ratios": [
          "16:9",
          "9:16",
          "1:1"
        ],
        "supports_reference_images": true,
        "supports_audio": false,
        "supports_dialogue": false
      },
      "rendering_rules": [
        "Render one prompt block per shot.",
        "Keep motion, camera, and lighting separate for review clarity.",
        "Prioritize cinematic clarity over dense lore."
      ],
      "output": {
        "format": "markdown",
        "file_extension": ".md",
        "naming_pattern": "{project_slug}-{package_id}-runway.md",
        "sections": [
          "Scene Summary",
          "Shot Prompts",
          "Camera Notes",
          "Reference Assets",
          "Negative Prompts"
        ]
      },
      "validation_rules": [
        "Every exported shot must include visual_prompt and camera.",
        "Warn if a shot lacks negative_prompt."
      ]
    },
