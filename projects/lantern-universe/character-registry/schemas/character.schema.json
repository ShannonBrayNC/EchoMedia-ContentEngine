{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echomedia.ai/schemas/lantern/character.schema.json",
  "title": "Lantern Universe Character Profile",
  "description": "Sprint PUB-007 schema for canonical Lantern Universe character registry records.",
  "type": "object",
  "required": [
    "sprint",
    "character_id",
    "display_name",
    "canon_status",
    "primary_series",
    "first_appearance",
    "role",
    "function",
    "motivations",
    "fears",
    "relationships",
    "continuity_notes",
    "producer_review_required"
  ],
  "properties": {
    "sprint": { "type": "string" },
    "character_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "display_name": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "canon_status": {
      "type": "string",
      "enum": ["canon-locked", "canon-draft", "concept-locked", "needs-review", "retired", "conflict"]
    },
    "primary_series": { "type": "string" },
    "first_appearance": { "type": "string" },
    "role": { "type": "string" },
    "function": { "type": "string" },
    "motivations": { "type": "array", "items": { "type": "string" } },
    "fears": { "type": "array", "items": { "type": "string" } },
    "relationships": { "type": "array", "items": { "type": "object" } },
    "continuity_notes": { "type": "array", "items": { "type": "string" } },
    "trauma_continuity": { "type": "array", "items": { "type": "string" } },
    "producer_review_required": { "type": "boolean" },
    "risk_flags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
