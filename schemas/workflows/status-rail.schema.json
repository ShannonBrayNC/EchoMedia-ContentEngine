{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echomedia.ai/schemas/content-engine/status-rail.schema.json",
  "title": "EchoMedia Content Engine Workflow Status Rail",
  "description": "Compact UI data contract for showing project, artifact, workflow stage, job state, review state, warnings, export readiness, and next action without a bulky order display.",
  "type": "object",
  "required": [
    "rail_id",
    "version",
    "project",
    "artifact",
    "workflow",
    "next_action",
    "updated_at"
  ],
  "properties": {
    "rail_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "project": {
      "$ref": "#/$defs/projectSummary"
    },
    "artifact": {
      "$ref": "#/$defs/artifactSummary"
    },
    "workflow": {
      "$ref": "#/$defs/workflowSummary"
    },
    "job": {
      "$ref": "#/$defs/jobSummary"
    },
    "review": {
      "$ref": "#/$defs/reviewSummary"
    },
    "traceability": {
      "$ref": "#/$defs/traceabilitySummary"
    },
    "export_readiness": {
      "$ref": "#/$defs/exportReadiness"
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/railMessage"
      },
      "default": []
    },
    "next_action": {
      "$ref": "#/$defs/nextAction"
    },
    "details_href": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "projectSummary": {
      "type": "object",
      "required": [
        "slug",
        "title",
        "status"
      ],
      "properties": {
        "slug": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "canon_state": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifactSummary": {
      "type": "object",
      "required": [
        "artifact_type"
      ],
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "artifact_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "destination_path": {
          "type": "string"
        },
        "preview_path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "workflowSummary": {
      "type": "object",
      "required": [
        "current_stage",
        "stage_status"
      ],
      "properties": {
        "current_stage": {
          "type": "string",
          "enum": [
            "select-project",
            "select-artifact",
            "load-context",
            "creative-direction",
            "validate-context",
            "generate-draft",
            "preview-review",
            "validate-draft",
            "approve",
            "export",
            "save-commit"
          ]
        },
        "stage_status": {
          "type": "string",
          "enum": [
            "not-started",
            "active",
            "blocked",
            "warning",
            "complete",
            "failed"
          ]
        },
        "completed_stages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "jobSummary": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "attempt": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "reviewSummary": {
      "type": "object",
      "properties": {
        "review_id": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "required_checks_total": {
          "type": "integer",
          "minimum": 0
        },
        "required_checks_passed": {
          "type": "integer",
          "minimum": 0
        },
        "blocking_failures": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "traceabilitySummary": {
      "type": "object",
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "sources_count": {
          "type": "integer",
          "minimum": 0
        },
        "downstream_count": {
          "type": "integer",
          "minimum": 0
        },
        "canon_impact": {
          "type": "string",
          "enum": [
            "none",
            "minor",
            "requires-review",
            "requires-change-request"
          ]
        }
      },
      "additionalProperties": false
    },
    "exportReadiness": {
      "type": "object",
      "properties": {
        "ready_profiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "blocked_profiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "selected_profile": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "railMessage": {
      "type": "object",
      "required": [
        "severity",
        "message"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ]
        },
        "message": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "nextAction": {
      "type": "object",
      "required": [
        "label",
        "action_key",
        "enabled"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "action_key": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "disabled_reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
