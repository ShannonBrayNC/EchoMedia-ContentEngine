{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echomedia.ai/schemas/deliverables/provider-neutral-deliverable.schema.json",
  "title": "Provider Neutral Deliverable Package",
  "description": "Canonical package contract for reviewed video/audio deliverables before provider-specific export adapters are invoked.",
  "type": "object",
  "required": [
    "package_id",
    "version",
    "project",
    "package_type",
    "state",
    "canonical_artifacts",
    "provider_views",
    "review_gate",
    "rights_safety",
    "quality_gates",
    "file_conventions",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "package_id": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "project": {
      "type": "object",
      "required": ["slug", "title", "root_path"],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "root_path": { "type": "string", "minLength": 1 },
        "series": { "type": "string" },
        "universe": { "type": "string" }
      }
    },
    "package_type": {
      "type": "string",
      "enum": ["scene", "sequence", "chapter", "trailer", "audiobook", "pitch", "production-bundle"]
    },
    "state": {
      "type": "string",
      "enum": ["draft", "needs-review", "approved", "export-ready", "exported", "blocked", "superseded"]
    },
    "canonical_artifacts": {
      "type": "object",
      "required": [
        "production_package",
        "scene_timeline",
        "screenplay_or_scene_cards",
        "visual_prompt_pack",
        "voice_package",
        "subtitle_caption_timing",
        "asset_manifest",
        "provider_export_manifest"
      ],
      "additionalProperties": false,
      "properties": {
        "production_package": { "$ref": "#/$defs/artifactRef" },
        "scene_timeline": { "$ref": "#/$defs/artifactRef" },
        "screenplay_or_scene_cards": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifactRef" }
        },
        "visual_prompt_pack": { "$ref": "#/$defs/artifactRef" },
        "voice_package": { "$ref": "#/$defs/artifactRef" },
        "subtitle_caption_timing": { "$ref": "#/$defs/artifactRef" },
        "asset_manifest": { "$ref": "#/$defs/artifactRef" },
        "provider_export_manifest": { "$ref": "#/$defs/artifactRef" },
        "optional_references": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" }
        }
      }
    },
    "provider_views": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/providerView" }
    },
    "review_gate": {
      "type": "object",
      "required": ["review_id", "state", "approved_by_human", "required_checks"],
      "additionalProperties": false,
      "properties": {
        "review_id": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "enum": ["pending-review", "approved", "rejected", "revision-requested", "blocked"] },
        "approved_by_human": { "type": "boolean" },
        "reviewed_at": { "type": ["string", "null"], "format": "date-time" },
        "reviewer_notes": { "type": "string" },
        "required_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" }
        }
      }
    },
    "rights_safety": {
      "type": "object",
      "required": [
        "source_rights_checked",
        "voice_rights_checked",
        "likeness_rights_checked",
        "provider_terms_checked",
        "release_disclosure_required",
        "blockers"
      ],
      "additionalProperties": false,
      "properties": {
        "source_rights_checked": { "type": "boolean" },
        "voice_rights_checked": { "type": "boolean" },
        "likeness_rights_checked": { "type": "boolean" },
        "provider_terms_checked": { "type": "boolean" },
        "release_disclosure_required": { "type": "boolean" },
        "notes": { "type": "string" },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "quality_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "file_conventions": {
      "type": "object",
      "required": ["package_root", "canonical_folder", "provider_export_folder", "manifest_path", "naming_pattern"],
      "additionalProperties": false,
      "properties": {
        "package_root": { "type": "string", "minLength": 1 },
        "canonical_folder": { "type": "string", "minLength": 1 },
        "provider_export_folder": { "type": "string", "minLength": 1 },
        "manifest_path": { "type": "string", "minLength": 1 },
        "naming_pattern": { "type": "string", "minLength": 1 }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "trace_id": { "type": "string" },
        "generation_job_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "artifactRef": {
      "type": "object",
      "required": ["artifact_id", "artifact_type", "path", "state"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "artifact_type": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "enum": ["draft", "needs-review", "approved", "export-ready", "exported", "blocked", "missing"] },
        "hash": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "providerView": {
      "type": "object",
      "required": ["provider", "profile_id", "target", "state", "required_inputs", "output_path", "validation"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["generic-json", "openai-video", "runway", "luma", "elevenlabs", "azure-speech", "openai-audio", "local-worker", "comfyui"]
        },
        "profile_id": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "enum": ["video", "audio", "image", "storyboard", "manifest", "local-worker"] },
        "state": { "type": "string", "enum": ["planned", "ready", "blocked", "exported"] },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "output_path": { "type": "string", "minLength": 1 },
        "validation": {
          "type": "object",
          "required": ["status", "messages"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "enum": ["not-run", "passed", "warning", "failed"] },
            "messages": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "check": {
      "type": "object",
      "required": ["key", "label", "status", "required"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["passed", "warning", "failed", "not-run"] },
        "required": { "type": "boolean" },
        "message": { "type": "string" }
      }
    }
  }
}
