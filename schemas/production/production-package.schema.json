{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echomedia.ai/schemas/content-engine/production-package.schema.json",
  "title": "EchoMedia Content Engine Production Package",
  "description": "Canonical structured package for pre-movie production artifacts that can be validated, previewed, and exported to AI video/audio/storyboard tools.",
  "type": "object",
  "required": [
    "package_id",
    "version",
    "project",
    "package_type",
    "source_refs",
    "scenes",
    "export_targets",
    "created_at"
  ],
  "properties": {
    "package_id": {
      "type": "string",
      "description": "Stable package identifier. Prefer project-slug plus artifact slug/date when generated."
    },
    "version": {
      "type": "string"
    },
    "project": {
      "$ref": "#/$defs/projectRef"
    },
    "package_type": {
      "type": "string",
      "enum": [
        "scene-package",
        "sequence-package",
        "trailer-package",
        "feature-package",
        "pitch-package",
        "audio-package",
        "tool-export-package"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "needs-review",
        "approved",
        "exported",
        "superseded",
        "archived"
      ],
      "default": "draft"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "canon_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      },
      "default": []
    },
    "visual_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      },
      "default": []
    },
    "characters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/characterRef"
      },
      "default": []
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scene"
      }
    },
    "global_style": {
      "$ref": "#/$defs/styleBlock"
    },
    "negative_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "continuity_notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "export_targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exportTarget"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    },
    "generation_job_id": {
      "type": "string"
    }
  },
  "$defs": {
    "projectRef": {
      "type": "object",
      "required": [
        "slug",
        "title",
        "root_path"
      ],
      "properties": {
        "slug": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "root_path": {
          "type": "string"
        },
        "universe": {
          "type": "string"
        },
        "series": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "sourceRef": {
      "type": "object",
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "canon",
            "character",
            "visual-bible",
            "manuscript",
            "screenplay",
            "story",
            "storyboard",
            "production-package",
            "external-note"
          ]
        },
        "path": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "characterRef": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "voice_notes": {
          "type": "string"
        },
        "visual_notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "scene": {
      "type": "object",
      "required": [
        "scene_id",
        "title",
        "purpose",
        "summary",
        "source_refs",
        "shots"
      ],
      "properties": {
        "scene_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "sequence": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "time_of_day": {
          "type": "string"
        },
        "characters": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        },
        "dialogue_or_narration": {
          "type": "string"
        },
        "audio_notes": {
          "type": "string"
        },
        "style": {
          "$ref": "#/$defs/styleBlock"
        },
        "shots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/shot"
          }
        }
      },
      "additionalProperties": false
    },
    "shot": {
      "type": "object",
      "required": [
        "shot_id",
        "description",
        "camera",
        "visual_prompt"
      ],
      "properties": {
        "shot_id": {
          "type": "string"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "description": {
          "type": "string"
        },
        "camera": {
          "type": "string"
        },
        "lighting": {
          "type": "string"
        },
        "motion": {
          "type": "string"
        },
        "visual_prompt": {
          "type": "string"
        },
        "negative_prompt": {
          "type": "string"
        },
        "reference_assets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "styleBlock": {
      "type": "object",
      "properties": {
        "tone": {
          "type": "string"
        },
        "visual_style": {
          "type": "string"
        },
        "camera_style": {
          "type": "string"
        },
        "color_palette": {
          "type": "string"
        },
        "pacing": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "exportTarget": {
      "type": "object",
      "required": [
        "profile",
        "status"
      ],
      "properties": {
        "profile": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "not-ready",
            "ready",
            "exported",
            "failed"
          ]
        },
        "output_path": {
          "type": "string"
        },
        "validation_notes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
