# EchoMedia Content Engine environment example
# Copy to .env.local for local development. Do not commit real secrets.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
CONTENT_ENGINE_ENV=local
CONTENT_ENGINE_NO_PROVIDER_MODE=true
CONTENT_ENGINE_LOG_LEVEL=info
CONTENT_ENGINE_REDACT_SECRETS=true
CONTENT_ENGINE_PROVIDER_ALLOWLIST=openai,elevenlabs,azure-speech,azure-openai,runway,luma,local-worker,comfyui,local-tts

# -----------------------------------------------------------------------------
# API/UI
# -----------------------------------------------------------------------------
CONTENT_ENGINE_API_HOST=127.0.0.1
CONTENT_ENGINE_API_PORT=8080
CONTENT_ENGINE_API_BASE_URL=http://127.0.0.1:8080
VITE_CONTENT_ENGINE_API_BASE_URL=http://127.0.0.1:8080
CONTENT_ENGINE_UI_PORT=5173

# -----------------------------------------------------------------------------
# Project and artifact paths
# -----------------------------------------------------------------------------
CONTENT_ENGINE_PROJECT_ROOT=./projects
CONTENT_ENGINE_CONFIG_ROOT=./config
CONTENT_ENGINE_SCHEMA_ROOT=./schemas
CONTENT_ENGINE_ARTIFACT_ROOT=./.content-engine/artifacts
CONTENT_ENGINE_DRAFT_ROOT=./.content-engine/drafts
CONTENT_ENGINE_EXPORT_ROOT=./.content-engine/exports
CONTENT_ENGINE_STATE_ROOT=./.content-engine/state

# -----------------------------------------------------------------------------
# Provider safety and budgets
# -----------------------------------------------------------------------------
CONTENT_ENGINE_ENABLE_LIVE_PROVIDERS=false
CONTENT_ENGINE_DRY_RUN_PROVIDERS=true
CONTENT_ENGINE_REQUIRE_APPROVAL_FOR_PAID_JOBS=true
CONTENT_ENGINE_MAX_ESTIMATED_RUN_COST_USD=5.00
CONTENT_ENGINE_MAX_ESTIMATED_PROJECT_COST_USD=50.00

# -----------------------------------------------------------------------------
# OpenAI text/audio/video provider
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_DEFAULT_TEXT_MODEL=
OPENAI_DEFAULT_AUDIO_MODEL=
OPENAI_DEFAULT_VIDEO_MODEL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# -----------------------------------------------------------------------------
# Azure OpenAI provider
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_TEXT_DEPLOYMENT=
AZURE_OPENAI_AUDIO_DEPLOYMENT=
AZURE_OPENAI_VIDEO_DEPLOYMENT=

# -----------------------------------------------------------------------------
# Azure Speech provider
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_DEFAULT_VOICE=
AZURE_USE_MANAGED_IDENTITY=false

# -----------------------------------------------------------------------------
# ElevenLabs provider
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_DEFAULT_MODEL_ID=

# -----------------------------------------------------------------------------
# Runway provider
# -----------------------------------------------------------------------------
RUNWAY_API_KEY=
RUNWAY_DEFAULT_MODEL=

# -----------------------------------------------------------------------------
# Luma / Dream Machine provider
# -----------------------------------------------------------------------------
LUMA_API_KEY=
LUMA_DEFAULT_MODEL=

# -----------------------------------------------------------------------------
# Kling / Pika provider placeholders
# Exact API settings must be verified before enabling live use.
# -----------------------------------------------------------------------------
KLING_API_KEY=
KLING_API_BASE_URL=
PIKA_API_KEY=
PIKA_API_BASE_URL=

# -----------------------------------------------------------------------------
# Local worker / Ubuntu media node
# -----------------------------------------------------------------------------
LOCAL_WORKER_ENABLED=false
LOCAL_WORKER_BASE_URL=http://127.0.0.1:8090
LOCAL_WORKER_SHARED_INPUT_ROOT=./.content-engine/worker-input
LOCAL_WORKER_SHARED_OUTPUT_ROOT=./.content-engine/worker-output
LOCAL_WORKER_TIMEOUT_SECONDS=3600

# -----------------------------------------------------------------------------
# Local TTS
# -----------------------------------------------------------------------------
LOCAL_TTS_ENABLED=false
LOCAL_TTS_ENGINE=
LOCAL_TTS_MODEL_PATH=
LOCAL_TTS_DEVICE=cpu
LOCAL_TTS_SAMPLE_RATE=24000

# -----------------------------------------------------------------------------
# ComfyUI local worker
# -----------------------------------------------------------------------------
COMFYUI_ENABLED=false
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_ROOT=./workers/comfyui/workflows

# -----------------------------------------------------------------------------
# Optional telemetry/diagnostics
# -----------------------------------------------------------------------------
CONTENT_ENGINE_ENABLE_TELEMETRY=false
CONTENT_ENGINE_DIAGNOSTICS_ROOT=./.content-engine/diagnostics
